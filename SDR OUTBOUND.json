        "jsCode": "const ctx = $('Prepara Contexto').item.json;\nconst raw = $input.item.json.choices?.[0]?.message?.content || '';\n\nlet ai;\ntry {\n  const match = raw.match(/\\{[\\s\\S]*\\}/);\n  ai = match ? JSON.parse(match[0]) : { resposta: raw, proximo_stage: ctx.stage };\n} catch(e) {\n  ai = { resposta: 'Desculpe, pode repetir?', proximo_stage: ctx.stage };\n}\n\nconst updatedData = { ...(ctx.collected_data || {}), ...(ai.dados_coletados || {}) };\nif (ai.produto_apresentado) updatedData.produto_apresentado = ai.produto_apresentado;\nif (ai.nivel_interesse)     updatedData.nivel_interesse     = ai.nivel_interesse;\n\nreturn {\n  lead_id: ctx.lead_id, phone: ctx.phone, name: ctx.name,\n  company: ctx.company, segment: ctx.segment,\n  resposta: ai.resposta, stage_atual: ctx.stage,\n  proximo_stage: ai.proximo_stage || ctx.stage,\n  collected_data: updatedData,\n  is_new_lead: ctx.is_new_lead,\n  is_returning_client: ctx.is_returning_client,\n  lead_message: ctx.message, agent_message: ai.resposta\n};"
      },
